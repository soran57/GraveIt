# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# PORT: The port the Express server will listen on.
PORT=3000

# NODE_ENV: Set to "production" to enable production mode (disables sandbox login).
NODE_ENV="development"

# GOOGLE_CLIENT_ID: Client ID for Google OAuth 2.0 logins.
GOOGLE_CLIENT_ID=""

# GOOGLE_CLIENT_SECRET: Client Secret for Google OAuth 2.0 authentication.
GOOGLE_CLIENT_SECRET=""

# JWT_SECRET: Private key used to sign session cookies securely.
# REQUIRED — the server will refuse to start without this.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# DATABASE_URL: PostgreSQL DSN. 
# Defaults to localhost for dev, but replace localhost with 'postgres' if running Node.js inside the docker network.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/graveit?sslmode=disable"

# REDIS_URL: Redis connection string.
# Defaults to localhost, but replace with 'redis' if running Node.js inside the docker network.
REDIS_URL="redis://localhost:6379"

# POSTGRES_PASSWORD: Used by docker-compose.prod.yml to set the database password.
# Generate a strong one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
POSTGRES_PASSWORD=""

# Paddle Billing configuration
PADDLE_CLIENT_TOKEN=""
PADDLE_PRICE_SMALL="pri_your_small_price_id_here"
PADDLE_PRICE_MEDIUM="pri_your_medium_price_id_here"
PADDLE_PRICE_LARGE="pri_your_large_price_id_here"
PADDLE_WEBHOOK_SECRET=""
